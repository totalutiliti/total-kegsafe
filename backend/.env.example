# Database
# ⚠️ PRODUÇÃO: Alterar para URL do banco de produção
DATABASE_URL="postgresql://postgres:postgres@localhost:5439/kegsafe_dev"

# JWT
# ⚠️ PRODUÇÃO: Gerar secrets fortes com: openssl rand -base64 32
# O sistema RECUSA iniciar em produção com secrets que contenham "dev", "change", "secret" ou "fallback"
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRATION="15m"
JWT_REFRESH_SECRET="your-refresh-token-secret-change-in-production"
JWT_REFRESH_EXPIRATION="7d"

# App
PORT=3009
# ⚠️ PRODUÇÃO: Alterar para "production"
NODE_ENV=development

# CORS — comma-separated origins allowed
# ⚠️ PRODUÇÃO: Alterar para domínio real (ex: https://kegsafe.seudominio.com.br)
CORS_ORIGINS="http://localhost:3010"
