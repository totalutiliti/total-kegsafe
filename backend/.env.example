# Database
# PRODUCAO: Alterar para URL do banco de producao
DATABASE_URL="postgresql://postgres:postgres@localhost:5439/kegsafe_dev"

# JWT
# PRODUCAO: Gerar secrets fortes com: openssl rand -base64 32
# O sistema RECUSA iniciar em producao com secrets que contenham "dev", "change", "secret" ou "fallback"
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRATION="15m"
JWT_REFRESH_SECRET="your-refresh-token-secret-change-in-production"
JWT_REFRESH_EXPIRATION="7d"

# Password Hashing — Argon2id Pepper
# PRODUCAO: Gerar com: openssl rand -base64 32 (minimo 32 caracteres)
# O pepper e concatenado a senha antes do hash. Se alterado, TODAS as senhas existentes se tornam invalidas.
PEPPER_SECRET="your-pepper-secret-minimum-32-chars-change-in-production"

# App
PORT=3009
# PRODUCAO: Alterar para "production"
NODE_ENV=development

# CORS — comma-separated origins allowed
# PRODUCAO: Alterar para dominio real (ex: https://kegsafe.seudominio.com.br)
CORS_ORIGINS="http://localhost:3010"

# Swagger — habilitar em producao (default: desabilitado)
# ENABLE_SWAGGER_DOCS=true

# Feature Flags — ligar/desligar funcionalidades sem deploy
FF_BATCH_IMPORT=true
FF_GEOFENCE=true
FF_DISPOSAL=true
FF_ALERTS=true
