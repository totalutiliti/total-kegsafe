// ============================================================================
// KegSafe Tech — Prisma Schema v2
// Sistema Multi-tenant SaaS para Gestão de Ativos (Barris de Chopp)
// 
// Convenções:
// - Todos os modelos de negócio DEVEM ter tenantId para isolamento multi-tenant
// - Soft delete implementado via campo deletedAt (nullable DateTime)
// - Campos de auditoria: createdAt, updatedAt, createdById, updatedById
// - Índices compostos otimizados para queries frequentes
// - Comentários detalhados em todos os campos importantes
// ============================================================================

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearch", "filteredRelationCount"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// TENANT & AUTH
// Gerenciamento de cervejarias (tenants) e autenticação de usuários
// ============================================================================

/// Representa uma cervejaria cliente do sistema (tenant)
/// Cada tenant tem isolamento completo de dados via RLS
model Tenant {
  /// Identificador único do tenant (UUID v4)
  id        String   @id @default(uuid()) @db.Uuid
  
  /// Nome completo/razão social da cervejaria
  /// Exemplo: "Cervejaria Petrópolis S.A."
  name      String   @db.VarChar(200)
  
  /// CNPJ da cervejaria (14 dígitos, sem formatação)
  /// Validação: Dígitos verificadores devem ser válidos
  cnpj      String   @unique @db.VarChar(14)
  
  /// Identificador amigável para URLs e referências
  /// Exemplo: "petropolis", "ambev-rj"
  /// Regex: ^[a-z0-9-]{3,50}$
  slug      String   @unique @db.VarChar(50)
  
  /// URL do logotipo da cervejaria (Azure Blob Storage)
  /// Formato: https://miro.medium.com/1*XAaLydZTUlM3HpmagpUKnA.png
  logoUrl   String?  @db.VarChar(500)
  
  /// Indica se o tenant está ativo no sistema
  /// false = suspensão por inadimplência ou solicitação
  isActive  Boolean  @default(true)
  
  /// Configurações específicas do tenant (JSON)
  /// Exemplo: { "idleThresholdDays": 15, "autoTriageEnabled": true }
  settings  Json?    @default("{}")
  
  /// Data de criação do registro
  createdAt DateTime @default(now()) @db.Timestamptz(3)
  
  /// Data da última atualização
  updatedAt DateTime @updatedAt @db.Timestamptz(3)
  
  /// Soft delete - se preenchido, tenant está inativo
  deletedAt DateTime? @db.Timestamptz(3)

  // Relacionamentos
  users              User[]
  barrels            Barrel[]
  clients            Client[]
  suppliers          Supplier[]
  serviceProviders   ServiceProvider[]
  geofences          Geofence[]
  componentConfigs   ComponentConfig[]
  alerts             Alert[]
  auditLogs          AuditLog[]

  @@map("tenants")
}

/// Usuário do sistema com perfil de acesso definido
/// Cada usuário pertence a exatamente um tenant
model User {
  /// Identificador único do usuário (UUID v4)
  id           String   @id @default(uuid()) @db.Uuid
  
  /// Tenant ao qual o usuário pertence (isolamento obrigatório)
  tenantId     String   @db.Uuid
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  /// Email do usuário (único por tenant)
  /// Usado para login e comunicações
  email        String   @db.VarChar(255)
  
  /// Hash da senha (bcrypt, salt rounds >= 10)
  /// NUNCA armazenar senha em texto plano
  passwordHash String   @db.VarChar(255)
  
  /// Nome completo do usuário para exibição
  name         String   @db.VarChar(150)
  
  /// Perfil de acesso que define permissões
  /// LOGISTICS: operações de campo (scan, expedição, entrega)
  /// MAINTENANCE: manutenção e triagem de barris
  /// MANAGER: dashboards, relatórios, aprovações
  /// ADMIN: configurações, cadastros, gestão de usuários
  role         Role
  
  /// Telefone para contato e recuperação de senha
  /// Formato: +5511999999999 (E.164)
  phone        String?  @db.VarChar(20)
  
  /// URL do avatar do usuário
  avatarUrl    String?  @db.VarChar(500)
  
  /// Indica se o usuário pode acessar o sistema
  /// false = desativado por admin ou tentativas de login falhas
  isActive     Boolean  @default(true)
  
  /// Timestamp do último login bem-sucedido
  lastLoginAt  DateTime? @db.Timestamptz(3)
  
  /// Contador de tentativas de login falhas (reset após sucesso)
  failedLoginAttempts Int @default(0)
  
  /// Timestamp do bloqueio por tentativas falhas
  lockedUntil  DateTime? @db.Timestamptz(3)
  
  /// Data de criação
  createdAt    DateTime @default(now()) @db.Timestamptz(3)
  
  /// Data da última atualização
  updatedAt    DateTime @updatedAt @db.Timestamptz(3)
  
  /// Soft delete
  deletedAt    DateTime? @db.Timestamptz(3)

  // Relacionamentos
  logisticsEvents   LogisticsEvent[]
  maintenanceLogs   MaintenanceLog[]
  triages           Triage[]
  disposalApprovals Disposal[] @relation("DisposalApprover")
  disposalRequests  Disposal[] @relation("DisposalRequester")
  auditLogs         AuditLog[]
  
  // Campos de auditoria para outros modelos
  barrelsCreated    Barrel[]   @relation("BarrelCreatedBy")
  barrelsUpdated    Barrel[]   @relation("BarrelUpdatedBy")
  clientsCreated    Client[]   @relation("ClientCreatedBy")
  clientsUpdated    Client[]   @relation("ClientUpdatedBy")
  geofencesCreated  Geofence[] @relation("GeofenceCreatedBy")
  geofencesUpdated  Geofence[] @relation("GeofenceUpdatedBy")
  logisticsCreated  LogisticsEvent[] @relation("LogisticsCreatedBy")
  maintenanceOrdersCreated MaintenanceOrder[] @relation("MaintenanceOrderCreatedBy")
  alertsCreated     Alert[]    @relation("AlertCreatedBy")

  // Índices
  @@unique([tenantId, email])
  @@index([tenantId])
  @@index([tenantId, role])
  @@index([tenantId, isActive])
  @@index([email]) // Para lookup no login
  @@map("users")
}

/// Perfis de acesso do sistema com permissões específicas
enum Role {
  LOGISTICS    // Operador de campo: scan, expedição, entrega, coleta, recebimento
  MAINTENANCE  // Técnico: manutenção, triagem, checklist
  MANAGER      // Gestor: dashboards, relatórios, aprovações, alertas
  ADMIN        // Administrador: configurações, usuários, integrações
}

/// Token de refresh para renovação de sessão
/// Permite manter usuário logado sem reautenticação frequente
model RefreshToken {
  /// Identificador único do token
  id        String   @id @default(uuid()) @db.Uuid
  
  /// Usuário dono do token
  userId    String   @db.Uuid
  
  /// Token criptografado (SHA-256 do token original)
  /// O token original é enviado ao cliente, armazenamos apenas o hash
  token     String   @unique @db.VarChar(255)
  
  /// Data de expiração do token (7 dias padrão)
  expiresAt DateTime @db.Timestamptz(3)
  
  /// IP do dispositivo que gerou o token
  ipAddress String?  @db.VarChar(45)
  
  /// User-Agent do dispositivo
  userAgent String?  @db.VarChar(500)
  
  /// Se o token foi revogado manualmente (logout)
  revoked   Boolean  @default(false)
  
  /// Data de criação
  createdAt DateTime @default(now()) @db.Timestamptz(3)

  @@index([userId])
  @@index([expiresAt])
  @@index([token])
  @@map("refresh_tokens")
}

// ============================================================================
// BARRIL (ATIVO PRINCIPAL)
// Entidade central do sistema - representa um barril de chopp físico
// ============================================================================

/// Barril de chopp - ativo principal rastreado pelo sistema
/// Cada barril tem um ciclo de vida completo: cadastro → uso → manutenção → descarte
model Barrel {
  /// Identificador único do barril (UUID v4)
  id              String       @id @default(uuid()) @db.Uuid
  
  /// Tenant proprietário do barril
  tenantId        String       @db.Uuid
  tenant          Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  /// Código interno de identificação (auto-gerado)
  /// Formato: KS-BAR-NNNNN (ex: KS-BAR-00001)
  /// Usado para referência em relatórios e comunicação
  internalCode    String       @db.VarChar(20)
  
  /// Código do QR Code físico gravado/colado no barril
  /// Escaneado pelo app mobile para identificação
  qrCode          String       @db.VarChar(50)
  
  /// Código de barras adicional (opcional, backup)
  barcode         String?      @db.VarChar(50)
  
  /// Fabricante do barril (ex: Franke, Portinox, Blefa)
  manufacturer    String?      @db.VarChar(100)
  
  /// Modelo da válvula do barril
  /// Determina compatibilidade com extratoras
  valveModel      ValveModel?
  
  /// Capacidade em litros (valores aceitos: 10, 20, 30, 50)
  capacityLiters  Int          @db.SmallInt
  
  /// Peso da tara (barril vazio) em kg
  /// Usado para calcular volume de produto
  tareWeightKg    Decimal?     @db.Decimal(6, 2)
  
  /// Material de construção do barril
  material        BarrelMaterial @default(INOX_304)
  
  /// Data de compra/aquisição do barril
  purchaseDate    DateTime?    @db.Date
  
  /// Data de fabricação (gravada no barril)
  manufactureDate DateTime?    @db.Date
  
  /// Custo de aquisição em R$ (para cálculo de TCO)
  acquisitionCost Decimal?     @db.Decimal(10, 2)
  
  /// Status atual no ciclo de vida
  /// Determina operações permitidas
  status          BarrelStatus @default(ACTIVE)
  
  /// Total de ciclos completos (expedição → recebimento)
  /// Incrementado a cada Input 4 (recebimento)
  totalCycles     Int          @default(0)
  
  /// Custo acumulado de todas as manutenções em R$
  /// Usado para cálculo de TCO e sugestão de descarte
  totalMaintenanceCost Decimal @default(0) @db.Decimal(12, 2)
  
  /// Última latitude conhecida (do último evento)
  currentLatitude  Decimal?    @db.Decimal(10, 7)
  
  /// Última longitude conhecida (do último evento)
  currentLongitude Decimal?    @db.Decimal(10, 7)
  
  /// Timestamp do último evento (logística ou manutenção)
  lastEventAt     DateTime?    @db.Timestamptz(3)
  
  /// Último cliente onde o barril foi entregue
  lastClientId    String?      @db.Uuid
  
  /// Soft delete - se preenchido, barril foi removido
  deletedAt       DateTime?    @db.Timestamptz(3)
  
  /// Data de criação do registro
  createdAt       DateTime     @default(now()) @db.Timestamptz(3)
  
  /// Data da última atualização
  updatedAt       DateTime     @updatedAt @db.Timestamptz(3)
  
  /// Usuário que criou o registro (auditoria)
  createdById     String?      @db.Uuid
  createdBy       User?        @relation("BarrelCreatedBy", fields: [createdById], references: [id])
  
  /// Usuário que fez a última atualização (auditoria)
  updatedById     String?      @db.Uuid
  updatedBy       User?        @relation("BarrelUpdatedBy", fields: [updatedById], references: [id])

  // Relacionamentos
  componentCycles   ComponentCycle[]
  logisticsEvents   LogisticsEvent[]
  maintenanceLogs   MaintenanceLog[]
  maintenanceOrders MaintenanceOrder[]
  alerts            Alert[]
  disposals         Disposal[]
  triages           Triage[]

  // Índices otimizados para queries frequentes
  @@unique([tenantId, internalCode])
  @@unique([tenantId, qrCode])
  @@index([tenantId, status])                           // Listagem por status
  @@index([tenantId, lastEventAt])                      // Ordenação temporal
  @@index([tenantId, status, lastEventAt])              // Filtro + ordenação
  @@index([tenantId, deletedAt])                        // Soft delete filter
  @@index([tenantId, totalCycles])                      // Ranking por uso
  @@index([tenantId, totalMaintenanceCost])             // Ranking por custo
  @@index([qrCode])                                     // Lookup por scan (cross-tenant check)
  @@index([tenantId, lastClientId])                     // Barris por cliente
  @@index([tenantId, capacityLiters, status])           // Filtro por capacidade
  @@map("barrels")
}

/// Status do barril no ciclo de vida
enum BarrelStatus {
  ACTIVE          // Na fábrica, disponível para expedição
  IN_TRANSIT      // Em trânsito (expedido ou coletado)
  AT_CLIENT       // Entregue no cliente (PDV)
  IN_MAINTENANCE  // Em manutenção na oficina
  BLOCKED         // Bloqueado por segurança (não pode ser usado)
  DISPOSED        // Descartado/baixa patrimonial
  LOST            // Extraviado (sem retorno há mais de 60 dias)
}

/// Modelos de válvula compatíveis com o mercado brasileiro
enum ValveModel {
  TYPE_S  // Sistema europeu (mais comum)
  TYPE_D  // Sistema alemão
  TYPE_A  // Sistema americano
  TYPE_G  // Sistema para gases
  TYPE_M  // Sistema misto
  OTHER   // Outros modelos especiais
}

/// Materiais de construção do barril
enum BarrelMaterial {
  INOX_304   // Aço inox 304 (padrão)
  INOX_316   // Aço inox 316 (maior resistência)
  PET_SLIM   // PET descartável (one-way)
}

// ============================================================================
// COMPONENTES DO BARRIL
// Sistema de manutenção preditiva baseado em ciclos e tempo
// ============================================================================

/// Configuração de componente de barril específica do tenant
/// Cada cervejaria pode ter seus próprios limites de manutenção
model ComponentConfig {
  /// Identificador único da configuração
  id                String          @id @default(uuid()) @db.Uuid
  
  /// Tenant dono da configuração
  tenantId          String          @db.Uuid
  tenant            Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  /// Nome do componente (ex: "Sifão", "O-Ring", "Válvula Principal")
  name              String          @db.VarChar(100)
  
  /// Descrição detalhada do componente e sua função
  description       String?         @db.VarChar(500)
  
  /// Vida útil máxima em ciclos de uso
  /// Ao atingir, componente precisa de manutenção
  maxCycles         Int
  
  /// Vida útil máxima em dias
  /// O que ocorrer primeiro (ciclos ou dias) dispara alerta
  maxDays           Int
  
  /// Nível de criticidade para priorização
  criticality       Criticality
  
  /// Percentual do limite para gerar alerta preventivo
  /// 0.9 = alerta quando atingir 90% do limite
  alertThreshold    Decimal         @default(0.9) @db.Decimal(3, 2)
  
  /// Se o componente está ativo para novos barris
  isActive          Boolean         @default(true)
  
  /// Custo médio de reposição (para estimativa de TCO)
  averageReplacementCost Decimal?   @db.Decimal(10, 2)
  
  /// Data de criação
  createdAt         DateTime        @default(now()) @db.Timestamptz(3)
  
  /// Data da última atualização
  updatedAt         DateTime        @updatedAt @db.Timestamptz(3)
  
  /// Soft delete
  deletedAt         DateTime?       @db.Timestamptz(3)

  // Relacionamentos
  componentCycles   ComponentCycle[]
  maintenanceItems  MaintenanceItem[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@index([tenantId, isActive])
  @@index([tenantId, criticality])
  @@map("component_configs")
}

/// Nível de criticidade do componente
enum Criticality {
  LOW       // Baixa: pode esperar manutenção programada
  MEDIUM    // Média: manutenção necessária em breve
  HIGH      // Alta: manutenção urgente
  CRITICAL  // Crítica: bloqueia uso do barril se vencido
}

/// Ciclo de manutenção de um componente específico em um barril específico
/// Rastreia uso desde a última manutenção para cálculo de saúde
model ComponentCycle {
  /// Identificador único
  id                    String          @id @default(uuid()) @db.Uuid
  
  /// Barril ao qual pertence este ciclo
  barrelId              String          @db.Uuid
  barrel                Barrel          @relation(fields: [barrelId], references: [id], onDelete: Cascade)
  
  /// Configuração do componente
  componentConfigId     String          @db.Uuid
  componentConfig       ComponentConfig @relation(fields: [componentConfigId], references: [id], onDelete: Cascade)
  
  /// Ciclos desde a última manutenção deste componente
  /// Resetado para 0 quando componente é mantido
  cyclesSinceLastService Int            @default(0)
  
  /// Data da última manutenção deste componente
  lastServiceDate       DateTime?       @db.Timestamptz(3)
  
  /// Score de saúde calculado (semáforo)
  /// Baseado em MAX(ciclos/limite, dias/limite)
  healthScore           HealthScore     @default(GREEN)
  
  /// Percentual exato de uso (para ordenação)
  healthPercentage      Decimal?        @db.Decimal(5, 2)
  
  /// Data de criação
  createdAt             DateTime        @default(now()) @db.Timestamptz(3)
  
  /// Data da última atualização
  updatedAt             DateTime        @updatedAt @db.Timestamptz(3)

  @@unique([barrelId, componentConfigId])
  @@index([barrelId])
  @@index([healthScore])
  @@index([barrelId, healthScore])
  @@index([componentConfigId, healthScore])
  @@map("component_cycles")
}

/// Score de saúde do componente (semáforo)
enum HealthScore {
  GREEN   // < 80% do limite: saudável
  YELLOW  // 80-99% do limite: atenção, manutenção preventiva recomendada
  RED     // >= 100% do limite: crítico, manutenção obrigatória
}

// ============================================================================
// LOGÍSTICA (4 INPUTS DE MOVIMENTAÇÃO)
// Rastreamento do ciclo logístico: expedição → entrega → coleta → recebimento
// ============================================================================

/// Evento de movimentação logística de um barril
/// Registra cada transição de status com geolocalização
model LogisticsEvent {
  /// Identificador único do evento
  id         String          @id @default(uuid()) @db.Uuid
  
  /// Tenant (para RLS)
  tenantId   String          @db.Uuid
  
  /// Barril que sofreu o evento
  barrelId   String          @db.Uuid
  barrel     Barrel          @relation(fields: [barrelId], references: [id], onDelete: Cascade)
  
  /// Usuário que registrou o evento
  userId     String          @db.Uuid
  user       User            @relation(fields: [userId], references: [id])
  
  /// Tipo de ação logística
  actionType LogisticsAction
  
  /// Latitude da localização no momento do scan
  /// Validação: -90 a 90
  latitude   Decimal         @db.Decimal(10, 7)
  
  /// Longitude da localização no momento do scan
  /// Validação: -180 a 180
  longitude  Decimal         @db.Decimal(10, 7)
  
  /// Precisão do GPS em metros
  gpsAccuracy Decimal?       @db.Decimal(8, 2)
  
  /// Cliente relacionado (para DELIVERY e COLLECTION)
  clientId   String?         @db.Uuid
  client     Client?         @relation(fields: [clientId], references: [id])
  
  /// Zona inferida pela geolocalização
  inferredZone GeofenceType?
  
  /// ID da geofence que correspondeu à localização
  matchedGeofenceId String?  @db.Uuid
  
  /// Notas adicionais do operador
  notes      String?         @db.VarChar(500)
  
  /// ID do lote (para scans em batch/metralhadora)
  batchId    String?         @db.Uuid
  
  /// Status anterior do barril (para auditoria)
  previousStatus BarrelStatus?
  
  /// Timestamp do evento (servidor, não cliente)
  timestamp  DateTime        @default(now()) @db.Timestamptz(3)

  /// Usuário que criou o registro (auditoria)
  createdById String?        @db.Uuid
  createdBy   User?          @relation("LogisticsCreatedBy", fields: [createdById], references: [id])

  // Índices otimizados para queries frequentes
  @@index([tenantId, barrelId])
  @@index([tenantId, timestamp])
  @@index([tenantId, actionType])
  @@index([tenantId, actionType, timestamp])
  @@index([barrelId, actionType, timestamp])
  @@index([tenantId, clientId])
  @@index([tenantId, userId, timestamp])
  @@index([batchId])
  @@index([tenantId, createdById])
  @@map("logistics_events")
}

/// Tipos de ação logística (4 inputs do sistema)
enum LogisticsAction {
  EXPEDITION  // Input 1: Saída da fábrica (ACTIVE → IN_TRANSIT)
  DELIVERY    // Input 2: Entrega no cliente (IN_TRANSIT → AT_CLIENT)
  COLLECTION  // Input 3: Coleta no cliente (AT_CLIENT → IN_TRANSIT)
  RECEPTION   // Input 4: Retorno à fábrica (IN_TRANSIT → ACTIVE, +1 ciclo)
}

// ============================================================================
// MANUTENÇÃO
// Gestão de ordens de serviço e registro de manutenções realizadas
// ============================================================================

/// Ordem de serviço de manutenção
/// Pode ser gerada automaticamente (preditiva) ou manualmente
model MaintenanceOrder {
  /// Identificador único da OS
  id              String             @id @default(uuid()) @db.Uuid
  
  /// Tenant (para RLS)
  tenantId        String             @db.Uuid
  
  /// Barril que precisa de manutenção
  barrelId        String             @db.Uuid
  barrel          Barrel             @relation(fields: [barrelId], references: [id], onDelete: Cascade)
  
  /// Número da OS legível (auto-gerado)
  /// Formato: OS-YYYYMMDD-NNNN
  orderNumber     String             @db.VarChar(20)
  
  /// Tipo de manutenção
  orderType       MaintenanceType
  
  /// Status atual da OS
  status          MaintenanceOrderStatus @default(PENDING)
  
  /// Prioridade de atendimento
  priority        AlertPriority      @default(MEDIUM)
  
  /// Descrição do problema/serviço necessário
  description     String             @db.VarChar(1000)
  
  /// Se foi gerada automaticamente pelo sistema de alertas
  autoGenerated   Boolean            @default(false)
  
  /// ID do alerta que gerou esta OS (se auto-gerada)
  sourceAlertId   String?            @db.Uuid
  
  /// Usuário técnico atribuído
  assignedToId    String?            @db.Uuid
  
  /// Prestador de serviço externo
  providerId      String?            @db.Uuid
  provider        ServiceProvider?   @relation(fields: [providerId], references: [id])
  
  /// Custo estimado da manutenção
  estimatedCost   Decimal?           @db.Decimal(10, 2)
  
  /// Custo real após conclusão
  actualCost      Decimal?           @db.Decimal(10, 2)
  
  /// Data/hora de conclusão
  completedAt     DateTime?          @db.Timestamptz(3)
  
  /// Data de criação
  createdAt       DateTime           @default(now()) @db.Timestamptz(3)
  
  /// Data da última atualização
  updatedAt       DateTime           @updatedAt @db.Timestamptz(3)
  
  /// Soft delete
  deletedAt       DateTime?          @db.Timestamptz(3)

  /// Usuário que criou o registro (auditoria)
  createdById     String?            @db.Uuid
  createdBy       User?              @relation("MaintenanceOrderCreatedBy", fields: [createdById], references: [id])

  // Relacionamento com log de manutenção (1:1)
  maintenanceLog  MaintenanceLog?

  @@index([tenantId, status])
  @@index([tenantId, barrelId])
  @@index([tenantId, priority, status])
  @@index([tenantId, assignedToId, status])
  @@index([tenantId, createdAt])
  @@index([orderNumber])
  @@index([tenantId, createdById])
  @@map("maintenance_orders")
}

/// Tipos de manutenção
enum MaintenanceType {
  PREVENTIVE  // Manutenção programada (baseada em ciclos/tempo)
  CORRECTIVE  // Manutenção após falha/dano
  PREDICTIVE  // Manutenção antecipada por alerta do sistema
}

/// Status da ordem de serviço
enum MaintenanceOrderStatus {
  PENDING     // Aguardando atendimento
  IN_PROGRESS // Em execução
  COMPLETED   // Concluída
  CANCELLED   // Cancelada
}

/// Registro de manutenção realizada
/// Contém o checklist preenchido pelo técnico
model MaintenanceLog {
  /// Identificador único do registro
  id                String          @id @default(uuid()) @db.Uuid
  
  /// Tenant (para RLS)
  tenantId          String          @db.Uuid
  
  /// Barril que recebeu manutenção
  barrelId          String          @db.Uuid
  barrel            Barrel          @relation(fields: [barrelId], references: [id], onDelete: Cascade)
  
  /// Técnico que realizou a manutenção
  userId            String          @db.Uuid
  user              User            @relation(fields: [userId], references: [id])
  
  /// OS relacionada (opcional, pode ser manutenção avulsa)
  maintenanceOrderId String?        @unique @db.Uuid
  maintenanceOrder  MaintenanceOrder? @relation(fields: [maintenanceOrderId], references: [id])
  
  /// Tipo de manutenção realizada
  maintenanceType   MaintenanceType
  
  /// Teste de pressão realizado e OK?
  pressureTestOk    Boolean?
  
  /// Valor do teste de pressão (bar)
  pressureTestValue Decimal?        @db.Decimal(5, 2)
  
  /// Lavagem/sanitização completada?
  washCompleted     Boolean?
  
  /// Observações gerais do técnico
  generalNotes      String?         @db.VarChar(1000)
  
  /// Localização da manutenção
  latitude          Decimal?        @db.Decimal(10, 7)
  longitude         Decimal?        @db.Decimal(10, 7)
  
  /// Custo total da manutenção (peças + mão de obra)
  totalCost         Decimal?        @db.Decimal(10, 2)
  
  /// Timestamp do registro
  timestamp         DateTime        @default(now()) @db.Timestamptz(3)

  // Itens do checklist
  items             MaintenanceItem[]

  @@index([tenantId, barrelId])
  @@index([tenantId, timestamp])
  @@index([tenantId, userId])
  @@index([tenantId, maintenanceType])
  @@map("maintenance_logs")
}

/// Item individual do checklist de manutenção
/// Representa ação em um componente específico
model MaintenanceItem {
  /// Identificador único
  id                String          @id @default(uuid()) @db.Uuid
  
  /// Log de manutenção pai
  maintenanceLogId  String          @db.Uuid
  maintenanceLog    MaintenanceLog  @relation(fields: [maintenanceLogId], references: [id], onDelete: Cascade)
  
  /// Componente que recebeu a ação
  componentConfigId String          @db.Uuid
  componentConfig   ComponentConfig @relation(fields: [componentConfigId], references: [id])
  
  /// Ação realizada no componente
  action            ComponentAction
  
  /// Custo específico deste item (peça/serviço)
  cost              Decimal?        @db.Decimal(10, 2)
  
  /// Observações específicas do item
  notes             String?         @db.VarChar(500)

  @@index([maintenanceLogId])
  @@index([componentConfigId])
  @@map("maintenance_items")
}

/// Ações possíveis em um componente durante manutenção
enum ComponentAction {
  INSPECTED  // Apenas inspecionado (OK)
  REPLACED   // Substituído por peça nova
  REPAIRED   // Reparado/ajustado
}

// ============================================================================
// TRIAGEM RÁPIDA
// Verificação rápida de integridade no recebimento de barris
// ============================================================================

/// Registro de triagem rápida de barril
/// Realizada no recebimento para separar barris com avaria
model Triage {
  /// Identificador único
  id          String      @id @default(uuid()) @db.Uuid
  
  /// Tenant (para RLS)
  tenantId    String      @db.Uuid
  
  /// Barril triado
  barrelId    String      @db.Uuid
  barrel      Barrel      @relation(fields: [barrelId], references: [id], onDelete: Cascade)
  
  /// Usuário que realizou a triagem
  userId      String      @db.Uuid
  user        User        @relation(fields: [userId], references: [id])
  
  /// Barril está íntegro? (true = OK, false = avaria detectada)
  intact      Boolean
  
  /// Tipo de dano detectado (se não íntegro)
  damageType  DamageType?
  
  /// Descrição detalhada do dano
  damageNotes String?     @db.VarChar(500)
  
  /// URL da foto do dano (Azure Blob)
  photoUrl    String?     @db.VarChar(500)
  
  /// Resultado da triagem (para onde o barril vai)
  result      TriageResult
  
  /// Timestamp da triagem
  timestamp   DateTime    @default(now()) @db.Timestamptz(3)

  @@index([tenantId, barrelId])
  @@index([tenantId, timestamp])
  @@index([tenantId, result])
  @@map("triages")
}

/// Tipos de dano identificáveis na triagem
enum DamageType {
  STRUCTURAL  // Dano estrutural (amassado, furo, rachadura)
  VALVE       // Problema na válvula
  SEAL        // Problema de vedação
  CORROSION   // Corrosão visível
  WELD        // Problema de solda
  OTHER       // Outros danos
}

/// Resultado/destino do barril após triagem
enum TriageResult {
  CLEARED_FOR_FILLING  // Liberado para lavagem e envase
  SENT_TO_MAINTENANCE  // Direcionado para manutenção
  BLOCKED              // Bloqueado por segurança (dano grave)
}

// ============================================================================
// ALERTAS
// Sistema de alertas inteligentes para gestão proativa
// ============================================================================

/// Alerta gerado pelo sistema
/// Pode ser de diversos tipos e prioridades
model Alert {
  /// Identificador único do alerta
  id          String        @id @default(uuid()) @db.Uuid
  
  /// Tenant (para RLS)
  tenantId    String        @db.Uuid
  tenant      Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  /// Barril relacionado (opcional, alguns alertas são gerais)
  barrelId    String?       @db.Uuid
  barrel      Barrel?       @relation(fields: [barrelId], references: [id], onDelete: Cascade)
  
  /// ID do componente relacionado (para alertas de fim de vida)
  componentConfigId String? @db.Uuid
  
  /// Tipo de alerta
  alertType   AlertType
  
  /// Prioridade para ordenação e notificação
  priority    AlertPriority
  
  /// Status atual do alerta
  status      AlertStatus   @default(ACTIVE)
  
  /// Título resumido do alerta
  title       String        @db.VarChar(200)
  
  /// Descrição detalhada com contexto
  description String        @db.VarChar(1000)
  
  /// Dados adicionais estruturados (JSON)
  /// Ex: { "lat": -23.55, "lng": -46.63, "distance": 1500 }
  metadata    Json?
  
  /// Quando o alerta foi visto por um usuário
  acknowledgedAt DateTime?  @db.Timestamptz(3)
  
  /// Usuário que viu o alerta
  acknowledgedById String?  @db.Uuid
  
  /// Quando o alerta foi resolvido
  resolvedAt  DateTime?     @db.Timestamptz(3)
  
  /// Usuário que resolveu o alerta
  resolvedById String?      @db.Uuid
  
  /// Notas de resolução
  resolutionNotes String?   @db.VarChar(500)
  
  /// Data de criação
  createdAt   DateTime      @default(now()) @db.Timestamptz(3)
  
  /// Data da última atualização
  updatedAt   DateTime      @updatedAt @db.Timestamptz(3)

  /// Usuário/sistema que criou o alerta (auditoria)
  createdById String?       @db.Uuid
  createdBy   User?         @relation("AlertCreatedBy", fields: [createdById], references: [id])

  // Constraint de deduplicação
  @@unique([tenantId, barrelId, alertType, status])
  
  // Índices para queries frequentes
  @@index([tenantId, status])
  @@index([tenantId, alertType])
  @@index([tenantId, priority])
  @@index([tenantId, status, priority])
  @@index([tenantId, barrelId, status])
  @@index([tenantId, createdAt])
  @@index([tenantId, createdById])
  @@map("alerts")
}

/// Tipos de alerta suportados pelo sistema
enum AlertType {
  COMPONENT_END_OF_LIFE   // Componente próximo do fim da vida útil
  MANDATORY_INSPECTION    // Inspeção obrigatória (componente crítico vencido)
  IDLE_AT_CLIENT          // Barril ocioso no cliente > 15 dias
  IDLE_AT_FACTORY         // Barril ocioso na fábrica > 7 dias
  GEOFENCE_VIOLATION      // Barril fora de zona conhecida
  AFTER_HOURS_MOVEMENT    // Movimentação fora do horário comercial
  SUPPLIER_SLA_BREACH     // Prestador não atendeu SLA
  DISPOSAL_SUGGESTED      // TCO alto, sugestão de descarte
}

/// Prioridade do alerta para ordenação e notificação
enum AlertPriority {
  CRITICAL  // Push + email imediato, badge vermelho
  HIGH      // Push + email, badge laranja
  MEDIUM    // Apenas dashboard, badge amarelo
  LOW       // Apenas dashboard, sem badge
}

/// Status do alerta no ciclo de vida
enum AlertStatus {
  ACTIVE       // Alerta ativo, requer atenção
  ACKNOWLEDGED // Alerta visto, mas não resolvido
  RESOLVED     // Alerta resolvido
}

// ============================================================================
// GEOFENCING
// Zonas geográficas para validação de localização
// ============================================================================

/// Zona geográfica para validação de operações
/// Define áreas permitidas para cada tipo de operação
model Geofence {
  /// Identificador único
  id          String       @id @default(uuid()) @db.Uuid
  
  /// Tenant (para RLS)
  tenantId    String       @db.Uuid
  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  /// Nome descritivo da zona
  /// Ex: "Fábrica Petrópolis", "Bar do Zé - Centro"
  name        String       @db.VarChar(150)
  
  /// Tipo de zona (determina regras aplicáveis)
  type        GeofenceType
  
  /// Latitude do centro da zona
  latitude    Decimal      @db.Decimal(10, 7)
  
  /// Longitude do centro da zona
  longitude   Decimal      @db.Decimal(10, 7)
  
  /// Raio da zona em metros
  radiusMeters Int         @default(500)
  
  /// Cliente vinculado (se tipo CLIENT)
  clientId    String?      @db.Uuid
  client      Client?      @relation(fields: [clientId], references: [id])
  
  /// Se a zona está ativa para validações
  isActive    Boolean      @default(true)
  
  /// Data de criação
  createdAt   DateTime     @default(now()) @db.Timestamptz(3)
  
  /// Data da última atualização
  updatedAt   DateTime     @updatedAt @db.Timestamptz(3)
  
  /// Soft delete
  deletedAt   DateTime?    @db.Timestamptz(3)

  /// Usuário que criou (auditoria)
  createdById String?      @db.Uuid
  createdBy   User?        @relation("GeofenceCreatedBy", fields: [createdById], references: [id])

  /// Usuário que fez a última atualização (auditoria)
  updatedById String?      @db.Uuid
  updatedBy   User?        @relation("GeofenceUpdatedBy", fields: [updatedById], references: [id])

  @@index([tenantId, type])
  @@index([tenantId, isActive])
  @@index([tenantId, clientId])
  @@index([tenantId, latitude, longitude])
  @@index([tenantId, createdById])
  @@map("geofences")
}

/// Tipos de zona geográfica
enum GeofenceType {
  FACTORY     // Fábrica/sede da cervejaria
  WAREHOUSE   // Armazém/centro de distribuição
  CLIENT      // Ponto de venda (bar, restaurante)
  RESTRICTED  // Zona proibida (alerta se barril aparecer)
}

// ============================================================================
// DESCARTE / BAIXA PATRIMONIAL
// Gestão do fim de vida útil do barril
// ============================================================================

/// Processo de descarte/baixa patrimonial de barril
/// Requer aprovação do MANAGER antes de conclusão
model Disposal {
  /// Identificador único
  id              String            @id @default(uuid()) @db.Uuid
  
  /// Tenant (para RLS)
  tenantId        String            @db.Uuid
  
  /// Barril a ser descartado
  barrelId        String            @db.Uuid
  barrel          Barrel            @relation(fields: [barrelId], references: [id], onDelete: Cascade)
  
  /// Usuário que solicitou/sugeriu o descarte
  requestedById   String            @db.Uuid
  requestedBy     User              @relation("DisposalRequester", fields: [requestedById], references: [id])
  
  /// Usuário que aprovou (se aprovado)
  approvedById    String?           @db.Uuid
  approvedBy      User?             @relation("DisposalApprover", fields: [approvedById], references: [id])
  
  /// Status do processo de descarte
  status          DisposalStatus    @default(SUGGESTED)
  
  /// Motivo da sugestão/solicitação de descarte
  reason          String            @db.VarChar(500)
  
  /// TCO acumulado até o momento em R$
  tcoAccumulated  Decimal           @db.Decimal(12, 2)
  
  /// Custo de reposição (barril novo) em R$
  replacementCost Decimal           @db.Decimal(10, 2)
  
  /// Destino final do barril (após aprovação)
  destination     DisposalDestination?
  
  /// Valor obtido na venda como sucata (se aplicável)
  scrapValue      Decimal?          @db.Decimal(10, 2)
  
  /// Notas adicionais
  notes           String?           @db.VarChar(1000)
  
  /// Data/hora da aprovação
  approvedAt      DateTime?         @db.Timestamptz(3)
  
  /// Data/hora da conclusão (destino registrado)
  completedAt     DateTime?         @db.Timestamptz(3)
  
  /// Data de criação
  createdAt       DateTime          @default(now()) @db.Timestamptz(3)
  
  /// Data da última atualização
  updatedAt       DateTime          @updatedAt @db.Timestamptz(3)

  @@index([tenantId, status])
  @@index([tenantId, barrelId])
  @@index([tenantId, createdAt])
  @@map("disposals")
}

/// Status do processo de descarte
enum DisposalStatus {
  SUGGESTED         // Sugerido pelo sistema (TCO alto)
  PENDING_APPROVAL  // Solicitado, aguardando aprovação
  APPROVED          // Aprovado, aguardando destino final
  COMPLETED         // Concluído (destino registrado)
  REJECTED          // Rejeitado pelo MANAGER
}

/// Destino final do barril descartado
enum DisposalDestination {
  SCRAP_SALE   // Venda como sucata de inox
  RECYCLING    // Reciclagem controlada
  DONATION     // Doação (ex: para projetos sociais)
}

// ============================================================================
// CLIENTES (PDVs)
// Pontos de venda que recebem os barris
// ============================================================================

/// Cliente/Ponto de Venda (bar, restaurante, etc)
model Client {
  /// Identificador único
  id           String   @id @default(uuid()) @db.Uuid
  
  /// Tenant (para RLS)
  tenantId     String   @db.Uuid
  
  /// Razão social do cliente
  name         String   @db.VarChar(200)
  
  /// Nome fantasia (exibido no app)
  tradeName    String?  @db.VarChar(200)
  
  /// CNPJ do cliente (14 dígitos, validado)
  cnpj         String?  @db.VarChar(14)
  
  /// Telefone principal
  phone        String?  @db.VarChar(20)
  
  /// Email de contato
  email        String?  @db.VarChar(255)
  
  /// Endereço completo
  address      String?  @db.VarChar(500)
  
  /// Latitude da localização
  latitude     Decimal? @db.Decimal(10, 7)
  
  /// Longitude da localização
  longitude    Decimal? @db.Decimal(10, 7)
  
  /// Tipo de extratora/sistema do cliente
  connectorType String? @db.VarChar(50)
  
  /// Se o cliente está ativo
  isActive     Boolean  @default(true)
  
  /// Data de criação
  createdAt    DateTime @default(now()) @db.Timestamptz(3)
  
  /// Data da última atualização
  updatedAt    DateTime @updatedAt @db.Timestamptz(3)
  
  /// Soft delete
  deletedAt    DateTime? @db.Timestamptz(3)

  /// Usuário que criou (auditoria)
  createdById  String?  @db.Uuid
  createdBy    User?    @relation("ClientCreatedBy", fields: [createdById], references: [id])

  /// Usuário que fez a última atualização (auditoria)
  updatedById  String?  @db.Uuid
  updatedBy    User?    @relation("ClientUpdatedBy", fields: [updatedById], references: [id])

  // Relacionamentos
  logisticsEvents LogisticsEvent[]
  geofences       Geofence[]

  @@unique([tenantId, cnpj])
  @@index([tenantId])
  @@index([tenantId, isActive])
  @@index([tenantId, latitude, longitude])
  @@index([tenantId, createdById])
  @@map("clients")
}

// ============================================================================
// FORNECEDORES E PRESTADORES
// Parceiros externos para suprimentos e serviços
// ============================================================================

/// Fornecedor de insumos e peças
model Supplier {
  /// Identificador único
  id              String   @id @default(uuid()) @db.Uuid
  
  /// Tenant (para RLS)
  tenantId        String   @db.Uuid
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  /// Nome/razão social do fornecedor
  name            String   @db.VarChar(200)
  
  /// CNPJ do fornecedor
  cnpj            String?  @db.VarChar(14)
  
  /// Tipo de suprimento fornecido
  supplyType      String   @db.VarChar(100)
  
  /// Lead time médio em dias
  leadTimeDays    Int?
  
  /// Email de contato
  contactEmail    String?  @db.VarChar(255)
  
  /// Telefone de contato
  contactPhone    String?  @db.VarChar(20)
  
  /// Condições de pagamento (ex: "30/60 dias")
  paymentTerms    String?  @db.VarChar(100)
  
  /// Se está ativo para novos pedidos
  isActive        Boolean  @default(true)
  
  /// Data de criação
  createdAt       DateTime @default(now()) @db.Timestamptz(3)
  
  /// Data da última atualização
  updatedAt       DateTime @updatedAt @db.Timestamptz(3)
  
  /// Soft delete
  deletedAt       DateTime? @db.Timestamptz(3)

  @@index([tenantId])
  @@index([tenantId, isActive])
  @@index([tenantId, supplyType])
  @@map("suppliers")
}

/// Prestador de serviços de manutenção
model ServiceProvider {
  /// Identificador único
  id              String   @id @default(uuid()) @db.Uuid
  
  /// Tenant (para RLS)
  tenantId        String   @db.Uuid
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  /// Nome/razão social do prestador
  name            String   @db.VarChar(200)
  
  /// Especialidade principal
  specialty       String   @db.VarChar(150)
  
  /// Certificações (ex: "NR-13, ISO 9001")
  certifications  String?  @db.VarChar(300)
  
  /// Valor da hora técnica em R$
  hourlyRate      Decimal? @db.Decimal(10, 2)
  
  /// Valor por serviço em R$
  serviceRate     Decimal? @db.Decimal(10, 2)
  
  /// Rating médio (1.00 a 5.00)
  rating          Decimal? @db.Decimal(3, 2)
  
  /// Quantidade de avaliações
  ratingCount     Int      @default(0)
  
  /// Email de contato
  contactEmail    String?  @db.VarChar(255)
  
  /// Telefone de contato
  contactPhone    String?  @db.VarChar(20)
  
  /// Se está ativo para novas OS
  isActive        Boolean  @default(true)
  
  /// Data de criação
  createdAt       DateTime @default(now()) @db.Timestamptz(3)
  
  /// Data da última atualização
  updatedAt       DateTime @updatedAt @db.Timestamptz(3)
  
  /// Soft delete
  deletedAt       DateTime? @db.Timestamptz(3)

  // Relacionamentos
  maintenanceOrders MaintenanceOrder[]

  @@index([tenantId])
  @@index([tenantId, isActive])
  @@index([tenantId, specialty])
  @@index([tenantId, rating])
  @@map("service_providers")
}

// ============================================================================
// AUDITORIA
// Registro de todas as ações críticas para compliance
// ============================================================================

/// Log de auditoria para rastreabilidade de ações
model AuditLog {
  /// Identificador único
  id         String   @id @default(uuid()) @db.Uuid
  
  /// Tenant (para RLS)
  tenantId   String   @db.Uuid
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  /// Usuário que executou a ação (null para sistema)
  userId     String?  @db.Uuid
  user       User?    @relation(fields: [userId], references: [id])
  
  /// Ação executada (verbo no passado)
  /// Ex: "BARREL_CREATED", "MAINTENANCE_LOGGED", "ALERT_RESOLVED"
  action     String   @db.VarChar(100)
  
  /// Tipo da entidade afetada
  /// Ex: "Barrel", "MaintenanceLog", "Alert", "User"
  entityType String   @db.VarChar(50)
  
  /// ID da entidade afetada
  entityId   String   @db.VarChar(50)
  
  /// Estado anterior da entidade (JSON)
  oldData    Json?
  
  /// Estado novo da entidade (JSON)
  newData    Json?
  
  /// IP de origem da requisição
  ipAddress  String?  @db.VarChar(45)
  
  /// User-Agent do cliente
  userAgent  String?  @db.VarChar(500)
  
  /// Timestamp do evento
  timestamp  DateTime @default(now()) @db.Timestamptz(3)

  @@index([tenantId, timestamp])
  @@index([tenantId, entityType, entityId])
  @@index([tenantId, action])
  @@index([tenantId, userId, timestamp])
  @@map("audit_logs")
}
