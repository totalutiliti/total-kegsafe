# ===========================================
# KegSafe Tech - Environment Variables
# ===========================================
# Copy this file to .env and fill with your actual values
# NEVER commit .env to git, only .env.example

# ===========================================
# DATABASE
# ===========================================
DATABASE_URL="postgresql://kegsafe:kegsafe@localhost:5432/kegsafe?schema=public"
POSTGRES_USER=kegsafe
POSTGRES_PASSWORD=kegsafe
POSTGRES_DB=kegsafe

# ===========================================
# AUTHENTICATION
# ===========================================
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-this-in-production
JWT_REFRESH_EXPIRES_IN=7d

# ===========================================
# AZURE SERVICES
# ===========================================
# Azure Blob Storage for images (barrel photos, damage reports)
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=your-account;AccountKey=your-key;EndpointSuffix=core.windows.net
AZURE_STORAGE_CONTAINER=kegsafe-images

# Azure Application Insights (optional for monitoring)
AZURE_APPINSIGHTS_INSTRUMENTATIONKEY=

# ===========================================
# REDIS (CACHE)
# ===========================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://localhost:6379
REDIS_TTL=300

# ===========================================
# EMAIL SERVICE (SENDGRID)
# ===========================================
SENDGRID_API_KEY=SG.your-sendgrid-api-key
SENDGRID_FROM_EMAIL=alertas@kegsafe.tech
SENDGRID_FROM_NAME=KegSafe Tech

# Alternative: Azure Communication Services
# AZURE_COMMUNICATION_CONNECTION_STRING=

# ===========================================
# PUSH NOTIFICATIONS (FIREBASE)
# ===========================================
FIREBASE_PROJECT_ID=kegsafe-prod
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@kegsafe-prod.iam.gserviceaccount.com

# ===========================================
# APPLICATION
# ===========================================
NODE_ENV=development
PORT=3000
API_PREFIX=/api
APP_NAME=KegSafe Tech

# ===========================================
# CORS
# ===========================================
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:19006

# ===========================================
# RATE LIMITING
# ===========================================
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_AUTH_MAX_REQUESTS=30

# ===========================================
# JOBS/CRON
# ===========================================
ENABLE_CRON_JOBS=true
ALERT_HEALTH_CHECK_CRON=0 6 * * *
ALERT_IDLE_BARRELS_CRON=0 8 * * *
ALERT_GEOFENCE_CRON=0 */1 * * *
REPORT_WEEKLY_CRON=0 7 * * 1
DISPOSAL_SUGGESTION_CRON=0 6 * * 3
CACHE_REFRESH_CRON=*/5 * * * *

# Phase 2 feature stubs (GPS offline, Redis cache). Set to true when Phase 2 is ready.
ENABLE_PHASE2_CRONS=false

# ===========================================
# LOGGING
# ===========================================
LOG_LEVEL=debug
LOG_FORMAT=json

# ===========================================
# FRONTEND WEB (NEXT.JS)
# ===========================================
NEXT_PUBLIC_API_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=KegSafe Tech

# ===========================================
# MOBILE APP (REACT NATIVE)
# ===========================================
EXPO_PUBLIC_API_URL=http://localhost:3000

# ===========================================
# GEOFENCING
# ===========================================
# Default radius for geofences (meters)
DEFAULT_GEOFENCE_RADIUS_METERS=500

# ===========================================
# DISPOSAL
# ===========================================
# Factor K for TCO calculation (0.6 to 0.7)
DISPOSAL_TCO_FACTOR=0.65
DISPOSAL_MAX_CORRECTIVE_MAINTENANCE_12M=3

# ===========================================
# ALERTS
# ===========================================
ALERT_IDLE_AT_CLIENT_DAYS=15
ALERT_IDLE_AT_FACTORY_DAYS=7
ALERT_COMPONENT_THRESHOLD=0.9

# ===========================================
# DEVELOPMENT ONLY
# ===========================================
# Enable Prisma Studio (only in dev)
ENABLE_PRISMA_STUDIO=true
# Enable Swagger docs (only in dev/staging)
ENABLE_SWAGGER_DOCS=true
